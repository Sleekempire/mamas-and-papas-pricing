,\n","    drop_first=True\n",")\n","\n","# ------------------------------------------------------------\n","# 6️⃣ Week fixed effects (better than sine/cosine)\n","# ------------------------------------------------------------\n","\n","df_elastic = pd.get_dummies(\n","    df_elastic,\n","    columns=[\"FiscalWeekNumber\"],\n","    drop_first=True\n",")\n","\n","# ------------------------------------------------------------\n","# 7️⃣ Feature list\n","# ------------------------------------------------------------\n","\n","base_features = [\n","    \"log_P\",\n","    \"PromoFlag\",\n","    \"Lag_1\"\n","]\n","\n","dummy_features = [\n","    c for c in df_elastic.columns\n","    if \"Description_\" in c or \"FiscalWeekNumber_\" in c\n","]\n","\n","features = base_features + dummy_features\n","features = [f for f in features if f in df_elastic.columns]\n","\n","X = df_elastic[features]\n","y = df_elastic[\"log_Q\"]\n","\n","# ------------------------------------------------------------\n","# 8️⃣ Time split\n","# ------------------------------------------------------------\n","\n","split_time = df_elastic[\"Time_Index\"].quantile(0.8)\n","\n","train_mask = df_elastic[\"Time_Index\"] <= split_time\n","\n","X_train = X[train_mask]\n","X_test  = X[~train_mask]\n","\n","y_train = y[train_mask]\n","y_test  = y[~train_mask]\n","\n","# ------------------------------------------------------------\n","# 9️⃣ Fit\n","# ------------------------------------------------------------\n","\n","model = LinearRegression()\n","model.fit(X_train, y_train)\n","\n","pred = model.predict(X_test)\n","\n","elasticity = model.coef_[features.index(\"log_P\")]\n","\n","print(\"============================================\")\n","print(\" ELASTICITY MODEL\")\n","print(\"============================================\")\n","print(\"Elasticity:\", round(elasticity,4))\n","print(\"R2:\", round(r2_score(y_test, pred),4))\n","print(\"RMSE:\", round(np.sqrt(mean_squared_error(y_test, pred)),4))"]},{"cell_type":