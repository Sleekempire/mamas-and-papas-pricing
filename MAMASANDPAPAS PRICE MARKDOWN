====\n","\n","df[\"log_Q\"] = np.log(df[\"Total_Qty\"])\n","df[\"log_P\"] = np.log(df[\"UnitPrice\"])\n","\n","# ============================================================\n","# 3️⃣ CREATE SAFE TIME INDEX\n","# ============================================================\n","\n","df[\"Time_Index\"] = (\n","    (df[\"FiscalYear\"] - df[\"FiscalYear\"].min()) * 52\n","    + df[\"FiscalWeekNumber\"]\n",")\n","\n","# ============================================================\n","# 4️⃣ CREATE STRUCTURAL FEATURES\n","# ============================================================\n","\n","def create_structural_features(data):\n","\n","    data = data.copy()\n","\n","    # ---- Seasonality ----\n","    data[\"Week_sin\"] = np.sin(2 * np.pi * data[\"FiscalWeekNumber\"] / 52)\n","    data[\"Week_cos\"] = np.cos(2 * np.pi * data[\"FiscalWeekNumber\"] / 52)\n","\n","    # ---- Lag features per SKU (log scale) ----\n","    data[\"Lag_1\"] = data.groupby(\"Description\")[\"log_Q\"].shift(1)\n","    data[\"Lag_2\"] = data.groupby(\"Description\")[\"log_Q\"].shift(2)\n","    data[\"Lag_4\"] = data.groupby(\"Description\")[\"log_Q\"].shift(4)\n","\n","    # ---- Rolling mean ----\n","    data[\"Rolling_Mean_4\"] = (\n","        data.groupby(\"Description\")[\"log_Q\"]\n","        .rolling(4)\n","        .mean()\n","        .reset_index(0, drop=True)\n","    )\n","\n","    return data\n","\n","df = create_structural_features(df)\n","\n","# Drop only rows with lag NA\n","df = df.dropna(subset=[\"Lag_1\",\"Lag_2\",\"Lag_4\",\"Rolling_Mean_4\"])\n","\n","# ============================================================\n","# 5️⃣ SPLIT BY TIME (NO LEAKAGE)\n","# ============================================================\n","\n","split_time = df[\"Time_Index\"].quantile(0.8)\n","\n","train_df = df[df[\"Time_Index\"] <= split_time].copy()\n","test_df  = df[df[\"Time_Index\"] > split_time].copy()\n","\n","# ============================================================\n","# 6️⃣ FEATURE SELECTION (UPGRADED)\n","# ============================================================\n","\n","features = [\n","    \"log_P\",\n","    \"Week_sin\",\n","    \"Week_cos\",\n","    \"PromoFlag\",\n","    \"Lag_1\",\n","    \"Lag_2\",\n","    \"Lag_4\",\n","    \"Rolling_Mean_4\"\n","]\n","\n","features = [c for c in features if c in df.columns]\n","\n","X_train = train_df[features]\n","y_train = train_df[\"log_Q\"]\n","\n","X_test = test_df[features]\n","y_test = test_df[\"log_Q\"]\n","\n","# ============================================================\n","# 7️⃣ TRAIN MODELS\n","# ============================================================\n","\n","lr = LinearRegression()\n","rf = RandomForestRegressor(\n","    n_estimators=500,\n","    max_depth=15,\n","    random_state=42,\n","    n_jobs=-1\n",")\n","\n","gbr = GradientBoostingRegressor(\n","    n_estimators=500,\n","    learning_rate=0.03,\n","    max_depth=4,\n","    random_state=42\n",")\n","\n","models = {\n","    \"LinearRegression\": lr,\n","    \"RandomForest\": rf,\n","    \"GradientBoosting\": gbr\n","}\n","\n","results = {}\n","\n","for name, model in models.items():\n","    model.fit(X_train, y_train)\n","    pred_log = model.predict(X_test)\n","\n","    # Convert back to actual quantity\n","    pred = np.exp(pred_log)\n","    actual = np.exp(y_test)\n","\n","    results[name] = round(r2_score(actual, pred),4)\n","\n","print(\"================================================\")\n","print(\"Model Comparison (R2)\")\n","print(\"================================================\")\n","print(results)\n","\n","best_model_name = max(results, key=results.get)\n","print(\"\\nBest Model:\", best_model_name)"]},{"cell_type":"markdown","metadata":{"id":"FJNGh46hdH0V"},"source":["BASELINE VISUALIZATION"]},{"cell_type":"markdown","metadata":{"id":"29Gm9IrOdO3K"},"source":["Actual vs Predicted"]},{"cell_type":"code","execution_count":57,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":564},"executionI