}}],"source":["\n","plt.figure(figsize=(8,5))\n","plt.plot(simulation_summary[\"Multiplier\"],\n","         simulation_summary[\"Total Demand\"])\n","plt.title(\"Demand Curve\")\n","plt.xlabel(\"Price Multiplier\")\n","plt.ylabel(\"Total Demand\")\n","plt.show()"]},{"cell_type":"markdown","metadata":{"id":"mWDgkF-M9ty9"},"source":["Reinforcement Learning Agent (Q-learning)"]},{"cell_type":"code","source":["import numpy as np\n","import pandas as pd\n","import random\n","\n","# =========================\n","# CONFIG\n","# =========================\n","SEED = 42\n","np.random.seed(SEED)\n","random.seed(SEED)\n","\n","PRICE_MIN = 0.90\n","PRICE_MAX = 1.10\n","N_ACTIONS = 7\n","EPISODES = 100        # keep moderate; increase later\n","ALPHA = 0.1\n","GAMMA = 0.95\n","EPSILON_START = 0.30\n","EPSILON_END = 0.05\n","EPSILON_DECAY = 0.995\n","\n","actions = np.linspace(PRICE_MIN, PRICE_MAX, N_ACTIONS)\n","\n","# =========================\n","# 1) ALIGN FEATURES WITH MODEL\n","# =========================\n","demand_features = list(best_model.feature_names_in_)\n","\n","missing = [f for f in demand_features if f not in df_model.columns]\n","if missing:\n","    raise ValueError(f\"df_model missing features required by best_model: {missing}\")\n","\n","df_rl = df_model.copy().reset_index(drop=True)\n","df_rl = df_rl.dropna(subset=demand_features + [\"UnitPrice\", \"UnitCost\"])  # safety\n","\n","print(\"RL using features:\", demand_features)\n","print(\"Rows used for RL:\", len(df_rl))\n","\n","# =========================\n","# 2) DISCRETIZER (KEY FIX)\n","# =========================\n","# We bin continuous features so Q-learning can generalize.\n","BIN_SPECS = {\n","    \"Lag_1\": 10,\n","    \"Lag_4\": 10,\n","    \"Rolling_Mean_4\": 10,\n","    \"Time_Index\": 10,\n","    \"log_P\": 10,          # log price will move with actions\n","}\n","\n","# Precompute bin edges from data (industry practice)\n","bin_edges = {}\n","for col, nbins in BIN_SPECS.items():\n","    if col in df_rl.columns:\n","        # quantile bins are robust to outliers\n","        bin_edges[col] = np.unique(np.quantile(df_rl[col].values, np.linspace(0, 1, nbins + 1)))\n","\n","def discretize_row(row):\n","    state = []\n","    for f in demand_features:\n","        if f in BIN_SPECS:\n","            edges = bin_edges[f]\n","            # digitize into 0..nbins-1\n","            b = int(np.digitize(row[f], edges[1:-1], right=True))\n","            state.append(b)\n","        elif f == \"PromoFlag\":\n","            state.append(int(row.get(\"PromoFlag\", 0)))\n","        elif f in [\"FiscalWeekNumber\"]:\n","            state.append(int(row[f]))\n","        elif f in [\"Week_sin\", \"Week_cos\"]:\n","            # bin sin/cos into coarse buckets\n","            b = int(np.floor((row[f] + 1) * 5))  # maps -1..1 to ~0..10\n","            state.append(b)\n","        else:\n","            # fallback: round numeric\n","            val = row[f]\n","            state.append(int(np.round(val, 3) * 1000) if isinstance(val, (float, np.floating)) else int(val))\n","    return tuple(state)\n","\n","# =========================\n","# 3) ENVIRONMENT\n","# =========================\n","class DynamicPricingEnv:\n","    def __init__(self, df, model, features):\n","        self.df = df.reset_index(drop=True)\n","        self.model = model\n","        self.features = features\n","        self.n = len(self.df)\n","        self.idx = 0\n","\n","    def reset(self):\n","        self.idx = 0\n","        row = self.df.iloc[self.idx]\n","        return discretize_row(row)\n","\n","    def step(self, multiplier):\n","        row = self.df.iloc[self.idx].copy()\n","\n","        # apply price action\n","        new_price = row[\"UnitPrice\"] * multiplier\n","        row[\"log_P\"] = np.log(new_price)\n","\n","        # build prediction vector in exact model feature order\n","        X = pd.DataFrame([[row[f] for f in self.features]], columns=self.features)\n","        pred_log_q = self.model.predict(X)[0]\n","        pred_q = np.exp(pred_log_q)\n","\n","        profit = (new_price - row[\"UnitCost\"]) * pred_q\n","\n","        # advance\n","        self.idx += 1\n","        done = self.idx >= self.n\n","        next_state = None if done else discretize_row(self.df.iloc[self.idx])\n","\n","        return next_state, profit, done, new_price, pred_q\n","\n","# =========================\n","# 4) Q-LEARNING AGENT\n","# =========================\n","class QLearningAgent:\n","    def __init__(self, actions, alpha, gamma, epsilon):\n","        self.actions = actions\n","        self.alpha = alpha\n","        self.gamma = gamma\n","        self.epsilon = epsilon\n","        self.q = {}  # state -> q-values array\n","\n","    def _ensure(self, state):\n","        if state not in self.q:\n","            self.q[state] = np.zeros(len(self.actions))\n","\n","    def choose(self, state):\n","        self._ensure(state)\n","        if random.random() < self.epsilon:\n","            return random.randint(0, len(self.actions)-1)\n","        return int(np.argmax(self.q[state]))\n","\n","    def update(self, state, a_idx, reward, next_state):\n","        self._ensure(state)\n","        q_sa = self.q[state][a_idx]\n","\n","        if next_state is None:\n","            target = reward\n","        else:\n","            self._ensure(next_state)\n","            target = reward + self.gamma * np.max(self.q[next_state])\n","\n","        self.q[state][a_idx] = q_sa + self.alpha * (target - q_sa)\n","\n","# =========================\n","# 5) TRAIN\n","# =========================\n","env = DynamicPricingEnv(df_rl, best_model, demand_features)\n","agent = QLearningAgent(actions, ALPHA, GAMMA, EPSILON_START)\n","\n","print(\"\\n===== TRAINING RL AGENT (DISCRETIZED STATES) =====\")\n","\n","for ep in range(1, EPISODES + 1):\n","    state = env.reset()\n","    done = False\n","    total_profit = 0.0\n","\n","    while not done:\n","        a_idx = agent.choose(state)\n","        mult = actions[a_idx]\n","        next_state, reward, done, _, _ = env.step(mult)\n","        agent.update(state, a_idx, reward, next_state)\n","        total_profit += reward\n","        state = next_state if next_state is not None else state\n","\n","    # epsilon decay\n","    agent.epsilon = max(EPSILON_END, agent.epsilon * EPSILON_DECAY)\n","\n","    if ep % 10 == 0:\n","        print(f\"Episode {ep:>3} | Profit: {total_profit:,.2f} | epsilon: {agent.epsilon:.3f} | states learned: {len(agent.q)}\")\n","\n","# =========================\n","# 6) EVALUATE POLICY + CLEAN TABLES\n","# =========================\n","print(\"\\n===== EVALUATING LEARNED POLICY =====\")\n","\n","state = env.reset()\n","done = False\n","rows = []\n","total_profit = 0.0\n","\n","# reset env index manually for clean pass\n","env.idx = 0\n","\n","while not done:\n","    state = discretize_row(env.df.iloc[env.idx])\n","    agent._ensure(state)  # safety\n","\n","    best_a = int(np.argmax(agent.q[state]))\n","    mult = actions[best_a]\n","\n","    next_state, reward, done, new_price, pred_q = env.step(mult)\n","    row = env.df.iloc[env.idx - 1]\n","\n","    rows.append({\n","        \"FiscalYear\": row.get(\"FiscalYear\", np.nan),\n","        \"FiscalWeekNumber\": row.get(\"FiscalWeekNumber\", np.nan),\n","        \"Description\": row.get(\"Description\", \"\"),\n","        \"Base Price\": row[\"UnitPrice\"],\n","        \"Chosen Multiplier\": float(mult),\n","        \"New Price\": float(new_price),\n","        \"Predicted Demand\": float(pred_q),\n","        \"Expected Profit\": float(reward)\n","    })\n","\n","    total_profit += reward\n","\n","rl_results = pd.DataFrame(rows)\n","\n","# Clear, distinct tables\n","policy_summary = rl_results.groupby(\"Description\", as_index=False).agg(\n","    Avg_Base_Price=(\"Base Price\", \"mean\"),\n","    Avg_New_Price=(\"New Price\", \"mean\"),\n","    Total_Demand=(\"Predicted Demand\", \"sum\"),\n","    Total_Profit=(\"Expected Profit\", \"sum\"),\n","    Most_Common_Multiplier=(\"Chosen Multiplier\", lambda x: x.value_counts().index[0])\n",").sort_values(\"Total_Profit\", ascending=False)\n","\n","action_distribution = rl_results[\"Chosen Multiplier\"].value_counts().sort_index().reset_index()\n","action_distribution.columns = [\"Multiplier\", \"Count\"]\n","\n","print(\"\\n==============================\")\n","print(\"DAILY RL PRICING (HEAD)\")\n","print(\"==============================\")\n","print(rl_results.head(10))\n","\n","print(\"\\n==============================\")\n","print(\"PER-PRODUCT POLICY SUMMARY (TOP 10)\")\n","print(\"==============================\")\n","print(policy_summary.head(10))\n","\n","print(\"\\n==============================\")\n","print(\"ACTION DISTRIBUTION\")\n","print(\"==============================\")\n","print(action_distribution)\n","\n","print(\"\\n==============================\")\n","print(\"TOTAL EXPECTED PROFIT (RL POLICY)\")\n","print(\"==============================\")\n","print(f\"{total_profit:,.2f}\")"],"metadata":{"id":"4ot1ewKWvtgr"},"execution_count":null,"outputs":[]}],"metadata":{"accelerator":"GPU","colab":{"gpuType":"A100","provenance":[],"authorship_tag":"ABX9TyPxFH3J8IIKI/qaL65wfWTC"},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"}},"nbformat":4,"nbformat_minor":0}