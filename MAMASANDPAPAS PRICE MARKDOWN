[df_sim[\"Baseline_Price\"].mean()],\n","    \"Total Demand\": [df_sim[\"Baseline_Demand\"].sum()]\n","})\n","\n","print(\"\\n==============================\")\n","print(\"HISTORICAL BASELINE SUMMARY\")\n","print(\"==============================\")\n","print(baseline_summary)\n","\n","# ============================================================\n","# 3️⃣ ECONOMIC SIMULATION FUNCTION\n","# ============================================================\n","\n","def run_simulation(data, elasticity, multipliers):\n","\n","    results = []\n","\n","    for m in multipliers:\n","\n","        temp = data.copy()\n","\n","        temp[\"Simulated_Price\"] = temp[\"Baseline_Price\"] * m\n","\n","        temp[\"Simulated_Demand\"] = (\n","            temp[\"Baseline_Demand\"] *\n","            (temp[\"Simulated_Price\"] / temp[\"Baseline_Price\"]) ** elasticity\n","        )\n","\n","        temp[\"Revenue\"] = (\n","            temp[\"Simulated_Price\"] * temp[\"Simulated_Demand\"]\n","        )\n","\n","        temp[\"Profit\"] = (\n","            (temp[\"Simulated_Price\"] - temp[\"UnitCost\"])\n","            * temp[\"Simulated_Demand\"]\n","        )\n","\n","        results.append({\n","            \"Multiplier\": m,\n","            \"Avg Price\": temp[\"Simulated_Price\"].mean(),\n","            \"Total Demand\": temp[\"Simulated_Demand\"].sum(),\n","            \"Total Revenue\": temp[\"Revenue\"].sum(),\n","            \"Total Profit\": temp[\"Profit\"].sum()\n","        })\n","\n","    return pd.DataFrame(results)\n","\n","# ============================================================\n","# 4️⃣ RUN PRICE OPTIMISATION\n","# ============================================================\n","\n","price_grid = np.linspace(0.7, 1.5, 150)\n","\n","simulation_summary = run_simulation(\n","    df_sim, ELASTICITY, price_grid\n",")\n","\n","print(\"\\n==============================\")\n","print(\"SIMULATION SUMMARY (HEAD)\")\n","print(\"==============================\")\n","print(simulation_summary.head())\n","\n","# ============================================================\n","# 5️⃣ FIND OPTIMAL PRICE\n","# ============================================================\n","\n","optimal_row = simulation_summary.loc[\n","    simulation_summary[\"Total Profit\"].idxmax()\n","]\n","\n","print(\"\\n==============================\")\n","print(\"OPTIMAL PRICING RESULT\")\n","print(\"==============================\")\n","print(optimal_row)\n","\n","# ============================================================\n","# 6️⃣ DETAILED PRODUCT TABLE AT OPTIMAL PRICE\n","# ============================================================\n","\n","opt_multiplier = optimal_row[\"Multiplier\"]\n","\n","df_optimal = df_sim.copy()\n","\n","df_optimal[\"Previous Price\"] = df_optimal[\"Baseline_Price\"]\n","df_optimal[\"Simulated Price\"] = df_optimal[\"Baseline_Price\"] * opt_multiplier\n","\n","df_optimal[\"Adjusted Demand\"] = (\n","    df_optimal[\"Baseline_Demand\"] *\n","    (df_optimal[\"Simulated Price\"] /\n","     df_optimal[\"Previous Price\"]) ** ELASTICITY\n",")\n","\n","df_optimal[\"Revenue\"] = (\n","    df_optimal[\"Simulated Price\"] *\n","    df_optimal[\"Adjusted Demand\"]\n",")\n","\n","df_optimal[\"Profit\"] = (\n","    (df_optimal[\"Simulated Price\"] - df_optimal[\"UnitCost\"])\n","    * df_optimal[\"Adjusted Demand\"]\n",")\n","\n","df_optimal[\"Margin %\"] = (\n","    (df_optimal[\"Simulated Price\"] - df_optimal[\"UnitCost\"])\n","    / df_optimal[\"Simulated Price\"]\n",")\n","\n","print(\"\\n==============================\")\n","print(\"DETAILED PRODUCT TABLE (HEAD)\")\n","print(\"==============================\")\n","\n","print(df_optimal[[\n","    \"FiscalYear\",\n","    \"FiscalWeekNumber\",\n","    \"Description\",\n","    \"Previous Price\",\n","    \"Simulated Price\",\n","    \"Adjusted Demand\",\n","    \"Revenue\",\n","    \"Profit\",\n","    \"Margin %\"\n","]].head())\n","\n","\n","\n","\n"]},{"cell_type":"markdown","metadata