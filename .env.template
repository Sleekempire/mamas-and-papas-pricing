# ─────────────────────────────────────────────
#  ENVIRONMENT CONFIGURATION TEMPLATE
#  Copy to .env and populate all values.
#  NEVER commit .env to source control.
# ─────────────────────────────────────────────

# ── Environment ──────────────────────────────
ENVIRONMENT=development        # development | staging | production
APP_NAME=PricingOptimiser
APP_VERSION=1.0.0
DEBUG=false                    # Set true only in development

# ── Security ─────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql://pricing_user:CHANGE_PASSWORD@localhost:5432/pricing_db
# For development without PostgreSQL (SQLite):
# DATABASE_URL=sqlite:///./pricing_dev.db

# ── Model Storage ─────────────────────────────
MODEL_STORE_PATH=./model_store

# ── Pricing Constraints ───────────────────────
MIN_MARGIN_PCT=0.15            # Minimum acceptable margin (15%)
PRICE_GRID_POINTS=20           # Resolution of price simulation grid
PRICE_LOWER_BOUND=0.80         # Minimum price as fraction of current
PRICE_UPPER_BOUND=1.20         # Maximum price as fraction of current
MAX_DAILY_PRICE_CHANGE=0.20    # Max single-day price change (20%)
STOCK_SAFETY_FACTOR=0.90       # Predicted demand cannot exceed 90% of stock

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_ADMIN=200/minute
RATE_LIMIT_ANALYST=100/minute
RATE_LIMIT_MERCHANDISER=60/minute
RATE_LIMIT_VIEWER=30/minute

# ── Response Controls ─────────────────────────
MAX_RESPONSE_SIZE_BYTES=1048576   # 1 MB
MAX_RECOMMENDATION_ROWS=500
SKU_QUERY_ANOMALY_THRESHOLD=10    # Queries per SKU per minute before flagging

# ── CORS ──────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO
AUDIT_LOG_ENABLED=true
